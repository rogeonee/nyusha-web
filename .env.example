AUTH_SECRET=replace-with-long-random-secret
POSTGRES_URL=postgresql://postgres:password@localhost:5432/nyusha
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key
AI_GATEWAY_API_KEY=your-ai-gateway-api-key
BLOB_READ_WRITE_TOKEN=your-vercel-blob-read-write-token
# Optional: defaults to "private". Set to "public" if your Blob store is public-only.
# BLOB_ACCESS=private
# Optional: Gemini Files reuse optimization controls
# GEMINI_FILES_REUSE_ENABLED=true
# GEMINI_FILES_REFRESH_SKEW_MINUTES=10
# GEMINI_FILES_REFRESH_MAX_PER_REQUEST=6
# GEMINI_FILES_UPLOAD_TIMEOUT_MS=30000
# GEMINI_FILES_POLL_TIMEOUT_MS=20000
FAMILY_ALLOWED_EMAILS=first@example.com,second@example.com
